# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Emails allowed to log into the dashboard (comma-separated)
ALLOWED_EMAILS=admin@anyone.fr,theo@anyone.fr,frere@anyone.fr

# Admin emails who can issue API tokens (comma-separated, subset of ALLOWED_EMAILS)
ADMIN_EMAILS=admin@anyone.fr
